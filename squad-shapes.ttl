@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix squad: <https://repolex.ai/ontology/kit/squad/> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .

# =============================================================================
# SQUAD KIT SHACL SHAPES
# =============================================================================
# Validates squad kit documents against the squad ontology.
# Run via: rudof validate --shapes squad-shapes.ttl --data <file.ttl>
#
# Conventions:
#   -link / -links properties → sh:nodeKind sh:IRI (must be references, not strings)
#   status fields             → sh:in (enumerated values from rdfs:comment)
#   required fields           → sh:minCount 1
# =============================================================================


# --- Agent ---

squad:AgentShape a sh:NodeShape ;
    sh:targetClass squad:Agent ;
    sh:property [
        sh:path squad:substrate ;
        sh:in ( "carbon" "silicon" ) ;
        sh:message "substrate must be 'carbon' or 'silicon'." ;
    ] ;
    sh:property [
        sh:path squad:role ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:message "Agent must have a role." ;
    ] ;
    sh:property [
        sh:path squad:agentEmail ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:message "Agent must have an agentEmail — this is the identity key." ;
    ] ;
    sh:property [
        sh:path squad:worksOn-links ;
        sh:nodeKind sh:IRI ;
        sh:message "worksOn-links must be an IRI reference to a squad:Project." ;
    ] .


# --- Message ---

squad:MessageShape a sh:NodeShape ;
    sh:targetClass squad:Message ;
    sh:property [
        sh:path squad:from-link ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:message "Message must have a from-link (IRI reference to sending agent)." ;
    ] ;
    sh:property [
        sh:path squad:to-links ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:message "Message must have at least one to-links (IRI reference to recipient agent)." ;
    ] ;
    sh:property [
        sh:path squad:messageStatus ;
        sh:in ( "open" "resolved" "acknowledged" ) ;
        sh:message "messageStatus must be 'open', 'resolved', or 'acknowledged'." ;
    ] ;
    sh:property [
        sh:path squad:priority ;
        sh:in ( "low" "normal" "high" "urgent" ) ;
        sh:message "priority must be 'low', 'normal', 'high', or 'urgent'." ;
    ] ;
    sh:property [
        sh:path squad:regarding-link ;
        sh:nodeKind sh:IRI ;
        sh:message "regarding-link must be an IRI reference." ;
    ] ;
    sh:property [
        sh:path squad:inReplyTo-link ;
        sh:nodeKind sh:IRI ;
        sh:message "inReplyTo-link must be an IRI reference to a squad:Message." ;
    ] .


# --- Decision ---

squad:DecisionShape a sh:NodeShape ;
    sh:targetClass squad:Decision ;
    sh:property [
        sh:path squad:decidedBy-links ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:message "Decision must have at least one decidedBy-links (IRI reference to agent)." ;
    ] ;
    sh:property [
        sh:path squad:outcome ;
        sh:in ( "pending" "implemented" "reverted" "superseded" ) ;
        sh:message "outcome must be 'pending', 'implemented', 'reverted', or 'superseded'." ;
    ] ;
    sh:property [
        sh:path squad:supersededBy-link ;
        sh:nodeKind sh:IRI ;
        sh:message "supersededBy-link must be an IRI reference to a squad:Decision." ;
    ] .


# --- Discovery ---

squad:DiscoveryShape a sh:NodeShape ;
    sh:targetClass squad:Discovery ;
    sh:property [
        sh:path squad:foundBy-link ;
        sh:nodeKind sh:IRI ;
        sh:message "foundBy-link must be an IRI reference to an agent." ;
    ] ;
    sh:property [
        sh:path squad:confidence ;
        sh:in ( "certain" "likely" "hypothesis" "hunch" ) ;
        sh:message "confidence must be 'certain', 'likely', 'hypothesis', or 'hunch'." ;
    ] .


# --- Task ---

squad:TaskShape a sh:NodeShape ;
    sh:targetClass squad:Task ;
    sh:property [
        sh:path squad:taskStatus ;
        sh:in ( "todo" "in-progress" "blocked" "done" "cancelled" ) ;
        sh:minCount 1 ;
        sh:message "Task must have a taskStatus: 'todo', 'in-progress', 'blocked', 'done', or 'cancelled'." ;
    ] ;
    sh:property [
        sh:path squad:assignedTo-link ;
        sh:nodeKind sh:IRI ;
        sh:message "assignedTo-link must be an IRI reference to an agent." ;
    ] ;
    sh:property [
        sh:path squad:blocks-links ;
        sh:nodeKind sh:IRI ;
        sh:message "blocks-links must be IRI references to squad:Task." ;
    ] ;
    sh:property [
        sh:path squad:blockedBy-links ;
        sh:nodeKind sh:IRI ;
        sh:message "blockedBy-links must be IRI references to squad:Task." ;
    ] ;
    sh:property [
        sh:path squad:relatedDecision-link ;
        sh:nodeKind sh:IRI ;
        sh:message "relatedDecision-link must be an IRI reference to a squad:Decision." ;
    ] .


# --- Project ---

squad:ProjectShape a sh:NodeShape ;
    sh:targetClass squad:Project ;
    sh:property [
        sh:path squad:projectStatus ;
        sh:in ( "planning" "active" "paused" "shipped" "archived" ) ;
        sh:message "projectStatus must be 'planning', 'active', 'paused', 'shipped', or 'archived'." ;
    ] ;
    sh:property [
        sh:path squad:squadMembers-links ;
        sh:nodeKind sh:IRI ;
        sh:message "squadMembers-links must be IRI references to squad:Agent." ;
    ] .
