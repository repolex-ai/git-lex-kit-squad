@prefix lex-o: <https://repolex.ai/ontology/lex-upper/> .
@prefix squad: <https://repolex.ai/ontology/kit/squad/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# =============================================================================
# SQUAD KIT ONTOLOGY
# =============================================================================
# Multi-agent squad memory. Carbon and silicon agents collaborate in a shared
# git repo. Each document type below becomes a `git lex create` command.
#
# Kit: squad
# Namespace: squad: = https://repolex.ai/ontology/kit/squad/
# Extends: lex-o: (upper ontology)
# Tags: Use fm:tags from frontmatter — no duplication.
#
# Document types (= valid `git lex create` commands):
#   agent, brief, decision, digest, discovery, freeform, message,
#   pod, proclamation, project, situation, task
#
# Design notes:
#   - Personal memory lives in soul kit, not here. Squad is for shared things.
#   - Formal research lives in lab kit. Squad `brief` is for lighter surveys
#     and proactive "here's what I looked into" documents.
#   - Shared properties (project, relatedTo, type) are declared WITHOUT
#     rdfs:domain so they can be used on any document without triggering
#     OWL inference side effects. RDF is open-world: any property can
#     appear on any resource.
#
# All constraints (required fields, enums, types) are encoded here.
# SHACL shapes are generated from this file — do not hand-edit shapes.
# =============================================================================

<https://repolex.ai/ontology/kit/squad> a owl:Ontology ;
    rdfs:label "Squad Kit Ontology" ;
    rdfs:comment "Multi-agent squad memory. Carbon and silicon agents collaborate via structured markdown in a shared git repo." ;
    owl:versionInfo "0.4" .


# =============================================================================
# ENUM DATATYPES
# =============================================================================

squad:SubstrateValue a rdfs:Datatype ;
    owl:oneOf ("carbon" "silicon") .

squad:MessageStatusValue a rdfs:Datatype ;
    owl:oneOf ("open" "resolved" "acknowledged") .

squad:PriorityValue a rdfs:Datatype ;
    owl:oneOf ("low" "normal" "high" "urgent") .

squad:OutcomeValue a rdfs:Datatype ;
    owl:oneOf ("pending" "implemented" "reverted" "superseded") .

squad:ConfidenceValue a rdfs:Datatype ;
    owl:oneOf ("certain" "likely" "hypothesis" "hunch") .

squad:TaskStatusValue a rdfs:Datatype ;
    owl:oneOf ("todo" "in-progress" "blocked" "done" "cancelled") .

squad:ProjectStatusValue a rdfs:Datatype ;
    owl:oneOf ("planning" "active" "paused" "shipped" "archived") .

squad:PodStatusValue a rdfs:Datatype ;
    owl:oneOf ("forming" "active" "paused" "completed" "disbanded") .

squad:BriefStatusValue a rdfs:Datatype ;
    owl:oneOf ("drafting" "published" "stale" "superseded") .

squad:DigestStatusValue a rdfs:Datatype ;
    owl:oneOf ("draft" "published") .


# =============================================================================
# DOCUMENT TYPES (each = a `git lex create` command)
# =============================================================================

# --- Squaddie ---
# Who's on the squad. Carbon (humans) and silicon (AI).
# Created once per member. Updated as roles change.
# soulId is the primary identifier, linking to the soul kit.

squad:Squaddie a owl:Class ;
    rdfs:subClassOf lex-o:Physical ;
    rdfs:label "Squaddie" ;
    rdfs:comment "A squad member — carbon or silicon. Identity tied to soulId from the soul kit." ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty squad:role ;
        owl:minCardinality 1
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty squad:soulEmail ;
        owl:minCardinality 1
    ] .

squad:soulId a owl:DatatypeProperty ;
    rdfs:label "soul id" ;
    rdfs:comment "Primary identifier — the agent's soulId from their soul kit repo. Lowercase, alphanumeric + hyphens." ;
    rdfs:domain squad:Squaddie ;
    rdfs:range xsd:string .

squad:substrate a owl:DatatypeProperty ;
    rdfs:label "substrate" ;
    rdfs:comment "What the agent runs on: 'carbon' (human) or 'silicon' (AI)." ;
    rdfs:domain squad:Squaddie ;
    rdfs:range squad:SubstrateValue .

squad:role a owl:DatatypeProperty ;
    rdfs:label "role" ;
    rdfs:comment "The agent's role on the squad (e.g., 'ontologist', 'coder', 'boss')." ;
    rdfs:domain squad:Squaddie ;
    rdfs:range xsd:string .

squad:expertise a owl:DatatypeProperty ;
    rdfs:label "expertise" ;
    rdfs:comment "Areas of expertise (e.g., 'rust', 'sparql', 'vibes')." ;
    rdfs:domain squad:Squaddie ;
    rdfs:range xsd:string .

squad:soulEmail a owl:DatatypeProperty ;
    rdfs:label "soul email" ;
    rdfs:comment "Soul email — the agent's unique identity. Matches git:authorEmail." ;
    rdfs:domain squad:Squaddie ;
    rdfs:range xsd:string .

squad:worksOn a owl:ObjectProperty ;
    rdfs:label "works on" ;
    rdfs:comment "Projects this agent is actively working on." ;
    rdfs:domain squad:Squaddie ;
    rdfs:range squad:Project .

# --- Message ---
# Inter-agent communication. Persistent, queryable, threaded.
# Replaces ephemeral chat. Git blame shows who wrote what.

squad:Message a owl:Class ;
    rdfs:subClassOf lex-o:Information ;
    rdfs:label "Message" ;
    rdfs:comment "A message from one agent to another. Persistent inter-agent communication." ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty squad:from ;
        owl:minCardinality 1
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty squad:to ;
        owl:minCardinality 1
    ] .

squad:from a owl:ObjectProperty ;
    rdfs:label "from" ;
    rdfs:comment "The agent who sent this message." ;
    rdfs:domain squad:Message ;
    rdfs:range squad:Squaddie .

squad:to a owl:ObjectProperty ;
    rdfs:label "to" ;
    rdfs:comment "The agent(s) this message is addressed to. May be multiple." ;
    rdfs:domain squad:Message ;
    rdfs:range squad:Squaddie .

squad:messageStatus a owl:DatatypeProperty ;
    rdfs:label "message status" ;
    rdfs:comment "Message status: 'open', 'resolved', 'acknowledged'." ;
    rdfs:domain squad:Message ;
    rdfs:range squad:MessageStatusValue .

squad:inReplyTo a owl:ObjectProperty ;
    rdfs:label "in reply to" ;
    rdfs:comment "The message this is a reply to. Creates conversation threads." ;
    rdfs:domain squad:Message ;
    rdfs:range squad:Message .

# --- Decision ---
# A choice that was made, with context and rationale.
# The "why" behind the "what". Queryable decision history.

squad:Decision a owl:Class ;
    rdfs:subClassOf lex-o:Decision ;
    rdfs:label "Decision" ;
    rdfs:comment "A recorded choice with context, rationale, and outcome." ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty squad:decidedBy ;
        owl:minCardinality 1
    ] .

squad:decidedBy a owl:ObjectProperty ;
    rdfs:label "decided by" ;
    rdfs:comment "The agent(s) who made this decision." ;
    rdfs:domain squad:Decision ;
    rdfs:range squad:Squaddie .

squad:alternatives a owl:DatatypeProperty ;
    rdfs:label "alternatives" ;
    rdfs:comment "Other options that were considered." ;
    rdfs:domain squad:Decision ;
    rdfs:range xsd:string .

squad:rationale a owl:DatatypeProperty ;
    rdfs:label "rationale" ;
    rdfs:comment "Why this option was chosen over alternatives." ;
    rdfs:domain squad:Decision ;
    rdfs:range xsd:string .

squad:outcome a owl:DatatypeProperty ;
    rdfs:label "outcome" ;
    rdfs:comment "What happened as a result: 'pending', 'implemented', 'reverted', 'superseded'." ;
    rdfs:domain squad:Decision ;
    rdfs:range squad:OutcomeValue .

squad:supersededBy a owl:ObjectProperty ;
    rdfs:label "superseded by" ;
    rdfs:comment "A later decision that replaces this one." ;
    rdfs:domain squad:Decision ;
    rdfs:range squad:Decision .

# --- Discovery ---
# Something learned incidentally while working on something else.
# Not formal research — the byproducts of doing the work.
# "I was debugging X and noticed Y."

squad:Discovery a owl:Class ;
    rdfs:subClassOf lex-o:Information ;
    rdfs:label "Discovery" ;
    rdfs:comment "An incidental finding, insight, or gotcha noticed while doing other work. Not the result of deliberate research — that's Brief. Not a formal experiment result — that's the lab kit." .

squad:foundBy a owl:ObjectProperty ;
    rdfs:label "found by" ;
    rdfs:comment "The agent who made this discovery." ;
    rdfs:domain squad:Discovery ;
    rdfs:range squad:Squaddie .

squad:implications a owl:DatatypeProperty ;
    rdfs:label "implications" ;
    rdfs:comment "What this discovery means for the project." ;
    rdfs:domain squad:Discovery ;
    rdfs:range xsd:string .

squad:confidence a owl:DatatypeProperty ;
    rdfs:label "confidence" ;
    rdfs:comment "How confident: 'certain', 'likely', 'hypothesis', 'hunch'." ;
    rdfs:domain squad:Discovery ;
    rdfs:range squad:ConfidenceValue .

# --- Brief ---
# Proactive research, surveys, analyses, competitive intel.
# "I went and looked at X, here's what exists in the world."
# Lighter than lab kit's formal Investigation/Synthesis.

squad:Brief a owl:Class ;
    rdfs:subClassOf lex-o:Information ;
    rdfs:label "Brief" ;
    rdfs:comment "A proactive research document — ecosystem surveys, competitive analyses, state-of-the-world reports. Lighter than formal lab research. Authored to inform the squad so they can act." .

squad:briefStatus a owl:DatatypeProperty ;
    rdfs:label "brief status" ;
    rdfs:comment "Brief lifecycle: 'drafting', 'published', 'stale', 'superseded'." ;
    rdfs:domain squad:Brief ;
    rdfs:range squad:BriefStatusValue .

squad:authoredBy a owl:ObjectProperty ;
    rdfs:label "authored by" ;
    rdfs:comment "The agent(s) who researched and wrote this brief." ;
    rdfs:domain squad:Brief ;
    rdfs:range squad:Squaddie .

squad:sources a owl:DatatypeProperty ;
    rdfs:label "sources" ;
    rdfs:comment "URLs, papers, repos, and other sources consulted." ;
    rdfs:domain squad:Brief ;
    rdfs:range xsd:string .

squad:takeaways a owl:DatatypeProperty ;
    rdfs:label "takeaways" ;
    rdfs:comment "The 'so what' of the brief — key conclusions for the squad." ;
    rdfs:domain squad:Brief ;
    rdfs:range xsd:string .

# --- Task ---
# A work item. Assigned, tracked, blocked/blocking.

squad:Task a owl:Class ;
    rdfs:subClassOf lex-o:Process ;
    rdfs:label "Task" ;
    rdfs:comment "A work item with assignment and status tracking." ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty squad:taskStatus ;
        owl:minCardinality 1
    ] .

squad:assignedTo a owl:ObjectProperty ;
    rdfs:label "assigned to" ;
    rdfs:comment "The agent responsible for this task." ;
    rdfs:domain squad:Task ;
    rdfs:range squad:Squaddie .

squad:taskStatus a owl:DatatypeProperty ;
    rdfs:label "task status" ;
    rdfs:comment "Task status: 'todo', 'in-progress', 'blocked', 'done', 'cancelled'." ;
    rdfs:domain squad:Task ;
    rdfs:range squad:TaskStatusValue .

squad:blocks a owl:ObjectProperty ;
    rdfs:label "blocks" ;
    rdfs:comment "Tasks that cannot proceed until this one is done." ;
    rdfs:domain squad:Task ;
    rdfs:range squad:Task .

squad:blockedBy a owl:ObjectProperty ;
    rdfs:label "blocked by" ;
    rdfs:comment "Tasks that must complete before this one can proceed." ;
    rdfs:domain squad:Task ;
    rdfs:range squad:Task .

squad:relatedDecision a owl:ObjectProperty ;
    rdfs:label "related decision" ;
    rdfs:comment "The decision that created or motivated this task." ;
    rdfs:domain squad:Task ;
    rdfs:range squad:Decision .

# --- Project ---
# What we're building. High-level context.

squad:Project a owl:Class ;
    rdfs:subClassOf lex-o:Concept ;
    rdfs:label "Project" ;
    rdfs:comment "A project the squad is working on." .

squad:repo a owl:DatatypeProperty ;
    rdfs:label "repo" ;
    rdfs:comment "GitHub repository URL or org/repo identifier." ;
    rdfs:domain squad:Project ;
    rdfs:range xsd:string .

squad:projectStatus a owl:DatatypeProperty ;
    rdfs:label "project status" ;
    rdfs:comment "Project status: 'planning', 'active', 'paused', 'shipped', 'archived'." ;
    rdfs:domain squad:Project ;
    rdfs:range squad:ProjectStatusValue .

squad:squadMembers a owl:ObjectProperty ;
    rdfs:label "squad members" ;
    rdfs:comment "Agents working on this project." ;
    rdfs:domain squad:Project ;
    rdfs:range squad:Squaddie .

# --- Pod ---
# A temporary working group within the squad focused on a specific
# project or set of tasks. Disbanded when the work is done.

squad:Pod a owl:Class ;
    rdfs:subClassOf lex-o:Concept ;
    rdfs:label "Pod" ;
    rdfs:comment "A temporary working group within the squad focused on a specific project or set of tasks. Forms, does the work, disbands." .

squad:podStatus a owl:DatatypeProperty ;
    rdfs:label "pod status" ;
    rdfs:comment "Pod lifecycle: 'forming', 'active', 'paused', 'completed', 'disbanded'." ;
    rdfs:domain squad:Pod ;
    rdfs:range squad:PodStatusValue .

squad:podMembers a owl:ObjectProperty ;
    rdfs:label "pod members" ;
    rdfs:comment "Agents in this pod." ;
    rdfs:domain squad:Pod ;
    rdfs:range squad:Squaddie .

squad:podProject a owl:ObjectProperty ;
    rdfs:label "pod project" ;
    rdfs:comment "The project this pod is working on." ;
    rdfs:domain squad:Pod ;
    rdfs:range squad:Project .

squad:podTasks a owl:ObjectProperty ;
    rdfs:label "pod tasks" ;
    rdfs:comment "Tasks the pod is responsible for. Optional — tasks can also be assigned directly to agents." ;
    rdfs:domain squad:Pod ;
    rdfs:range squad:Task .

# --- Proclamation ---
# An announcement from the king of the squad. Authoritative, memorable,
# dated. Not a message to a specific agent — a decree for the whole squad.

squad:Proclamation a owl:Class ;
    rdfs:subClassOf lex-o:Information ;
    rdfs:label "Proclamation" ;
    rdfs:comment "A decree or announcement for the whole squad. Issued with authority, meant to be remembered. The King of the Squad speaks." ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty squad:proclaimedBy ;
        owl:minCardinality 1
    ] .

squad:proclaimedBy a owl:ObjectProperty ;
    rdfs:label "proclaimed by" ;
    rdfs:comment "The agent who issued the proclamation. Traditionally the King of the Squad." ;
    rdfs:domain squad:Proclamation ;
    rdfs:range squad:Squaddie .

# --- Situation ---
# A status report — what's happening, what's coming, what's on the
# agent's or pod's mind. Not a commit log, more of a vibe check with
# structure. Situation report. Sitrep.

squad:Situation a owl:Class ;
    rdfs:subClassOf lex-o:Information ;
    rdfs:label "Situation" ;
    rdfs:comment "A situation report. Current state of work, what's next, what's blocking. Links agents, projects, tasks, and briefs into a coherent snapshot." .

squad:situationAuthor a owl:ObjectProperty ;
    rdfs:label "situation author" ;
    rdfs:comment "The agent or pod reporting the situation." ;
    rdfs:domain squad:Situation ;
    rdfs:range squad:Squaddie .

squad:currentFocus a owl:DatatypeProperty ;
    rdfs:label "current focus" ;
    rdfs:comment "What the author is working on right now." ;
    rdfs:domain squad:Situation ;
    rdfs:range xsd:string .

squad:nextUp a owl:DatatypeProperty ;
    rdfs:label "next up" ;
    rdfs:comment "What comes next. Not a commitment — a direction." ;
    rdfs:domain squad:Situation ;
    rdfs:range xsd:string .

squad:blockers a owl:DatatypeProperty ;
    rdfs:label "blockers" ;
    rdfs:comment "What's in the way. Who or what the author is waiting on." ;
    rdfs:domain squad:Situation ;
    rdfs:range xsd:string .

# --- Freeform ---
# The catch-all. For thoughts, fragments, half-formed ideas, or anything
# that doesn't fit another type. Rely on [[wikilinks]] in the body and
# any shared ObjectProperty in the frontmatter.
#
# Use the `type` field to hint at what this document is really about.
# Patterns in the `type` field become candidates for new document types.

squad:Freeform a owl:Class ;
    rdfs:subClassOf lex-o:Information ;
    rdfs:label "Freeform" ;
    rdfs:comment "The catch-all. For thoughts, fragments, and documents that don't fit other types. Any shared ObjectProperty can be used in frontmatter. Set `type` to a short string to hint at what this document is — patterns in `type` become candidates for new classes." .

squad:type a owl:DatatypeProperty ;
    rdfs:label "type" ;
    rdfs:comment "A user-defined type hint for the document. Free-form string. Used to identify patterns that might become formal classes. Examples: 'retrospective', 'gripe', 'idea', 'question'." ;
    rdfs:domain squad:Freeform ;
    rdfs:range xsd:string .


# =============================================================================
# SHARED PROPERTIES
# =============================================================================
# These properties can be used on any document type — Freeform notes,
# Tasks, Situations, Briefs, whatever. They are declared WITHOUT rdfs:domain
# to avoid OWL inference side effects. In open-world RDF, any resource can
# have any property.

squad:project a owl:ObjectProperty ;
    rdfs:label "project" ;
    rdfs:comment "Which project this document relates to. Usable on any document type." ;
    rdfs:range squad:Project .

squad:pod a owl:ObjectProperty ;
    rdfs:label "pod" ;
    rdfs:comment "Which pod this document relates to. Usable on any document type." ;
    rdfs:range squad:Pod .

squad:relatedTo a owl:ObjectProperty ;
    rdfs:label "related to" ;
    rdfs:comment "Other entities this document references. Usable on any document type. Range is open — can point to any entity in the graph." .

squad:mentions a owl:ObjectProperty ;
    rdfs:label "mentions" ;
    rdfs:comment "Agents or entities mentioned in this document. Extracted from body wikilinks by default, but can be declared in frontmatter for explicit tagging." .

squad:regarding a owl:ObjectProperty ;
    rdfs:label "regarding" ;
    rdfs:comment "The entity this document is about. Useful on Messages, Situations, Briefs, Freeforms." .

squad:priority a owl:DatatypeProperty ;
    rdfs:label "priority" ;
    rdfs:comment "Priority hint: 'low', 'normal', 'high', 'urgent'. Usable on any document type." ;
    rdfs:range squad:PriorityValue .


# =============================================================================
# REASONING SUPPORT
# =============================================================================

squad:blockedBy owl:inverseOf squad:blocks .
